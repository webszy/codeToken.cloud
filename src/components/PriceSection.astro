---
const priceRows = [
  {
    model: "GPT-5.5",
    officialInput: "$5.00",
    cachedInput: "$0.50",
    officialOutput: "$30.00",
    avgOfficial: "$6.76",
    codeToken: "$1.01"
  },
  {
    model: "Claude Opus 4.8",
    officialInput: "$15.00",
    cachedInput: "$1.50",
    officialOutput: "$75.00",
    avgOfficial: "$15.82",
    codeToken: "$2.37"
  }
];

const comparisonRows = [
  {
    model: "GPT-5.5",
    officialCapacity: 0.148,
    codeTokenCapacity: 0.986,
    accent: "primary"
  },
  {
    model: "Claude Opus",
    officialCapacity: 0.063,
    codeTokenCapacity: 0.422,
    accent: "tertiary"
  }
];

const assumptions = [
  ["Input", "80%"],
  ["Output", "20%"],
  ["Cache Hit", "90%"],
  ["Multiplier", "0.15x"]
];
---

<section id="pricing" class="price-section relative z-10 overflow-hidden py-24 md:py-28">
  <div class="pointer-events-none absolute left-[18%] top-[18%] h-80 w-80 rounded-full bg-primary/10 blur-[110px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-[12%] right-[12%] h-80 w-80 rounded-full bg-[rgb(var(--tertiary)_/_0.1)] blur-[120px]" aria-hidden="true"></div>

  <div class="site-container relative z-10">
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.18em] text-primary">
        <span id="priceBegin" class="h-2 w-2 rounded-full bg-primary shadow-[0_0_10px_rgba(138,235,255,0.9)]"></span>
        Pricing
      </div>
      <h2 class="headline-gradient pb-2 font-display text-[38px] font-bold leading-[1.12] tracking-normal md:text-[56px]">
        Pay as You Go Pricing
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-[18px] leading-[1.7] text-muted">
        Recharge credits and use them across OpenAI, Codex, Claude, and multi-model AI workflows. No monthly subscription required.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <div class="space-y-6 lg:col-span-7">
        <div class="price-panel neon-border overflow-hidden rounded-lg">
          <div class="overflow-x-auto">
            <table class="min-w-[820px] w-full border-collapse text-left">
              <thead>
                <tr class="border-b border-border/40 bg-[rgb(var(--surface-container)_/_0.45)] font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.12em] text-muted">
                  <th class="px-6 py-4">Model</th>
                  <th class="px-6 py-4">Official Input<br /><span class="text-[10px] font-normal lowercase tracking-normal text-muted/70">/1M tokens</span></th>
                  <th class="px-6 py-4">Cached Input<br /><span class="text-[10px] font-normal lowercase tracking-normal text-muted/70">/1M tokens</span></th>
                  <th class="px-6 py-4">Official Output<br /><span class="text-[10px] font-normal lowercase tracking-normal text-muted/70">/1M tokens</span></th>
                  <th class="px-6 py-4">Avg Official<br /><span class="text-[10px] font-normal lowercase tracking-normal text-muted/70">/1M tokens</span></th>
                  <th class="px-6 py-4 text-primary">CodeToken<br /><span class="text-[10px] font-normal lowercase tracking-normal text-muted/70">/1M tokens</span></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border/25 font-mono text-[14px] leading-[1.5]">
                {
                  priceRows.map((row) => (
                    <tr class="transition-colors hover:bg-[rgb(var(--surface-container)_/_0.34)]">
                      <td class="px-6 py-4 font-semibold text-foreground">{row.model}</td>
                      <td class="px-6 py-4 text-muted">{row.officialInput}</td>
                      <td class="px-6 py-4 text-muted">{row.cachedInput}</td>
                      <td class="px-6 py-4 text-muted">{row.officialOutput}</td>
                      <td class="px-6 py-4 text-muted/55 line-through">{row.avgOfficial}</td>
                      <td class="glow-text px-6 py-4 font-bold text-primary">{row.codeToken}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <div class="price-panel rounded-lg border border-border/40 bg-[rgb(var(--surface-lowest)_/_0.72)] p-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-muted" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 17V11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <path d="M12 7.25V7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                <path d="M21 12A9 9 0 1 1 3 12A9 9 0 0 1 21 12Z" stroke="currentColor" stroke-width="1.8" />
              </svg>
              <span class="font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.16em] text-muted">Assumptions</span>
            </div>
            <div class="flex flex-wrap gap-4 font-mono text-[14px] text-muted">
              {
                assumptions.map(([label, value]) => (
                  <div>
                    {label}: <span class:list={["font-semibold", label === "Multiplier" ? "text-[rgb(var(--tertiary))]" : "text-foreground"]}>{value}</span>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="mt-3 border-t border-border/30 pt-3 text-[12px] leading-relaxed text-muted/70">
            Avg Official = (Input * % + Output * %) | CodeToken = Avg Official * Multiplier (adjusted for cache)
          </div>
        </div>
      </div>

      <div class="relative lg:col-span-5" data-price-calculator>
        <div class="pointer-events-none absolute inset-0 opacity-40 mix-blend-screen" aria-hidden="true">
          <svg class="h-full w-full" viewBox="0 0 420 520" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M210 24L372 118V306L210 400L48 306V118L210 24Z" stroke="url(#price-hex-a)" stroke-width="1.4" stroke-dasharray="7 9" />
            <path d="M210 82L322 147V276L210 341L98 276V147L210 82Z" stroke="url(#price-hex-b)" stroke-width="1" stroke-dasharray="3 10" />
            <defs>
              <linearGradient id="price-hex-a" x1="48" x2="372" y1="24" y2="400">
                <stop stop-color="#8AEBFF" />
                <stop offset="1" stop-color="#D9B0FF" />
              </linearGradient>
              <linearGradient id="price-hex-b" x1="98" x2="322" y1="82" y2="341">
                <stop stop-color="#D9B0FF" />
                <stop offset="1" stop-color="#8AEBFF" />
              </linearGradient>
            </defs>
          </svg>
        </div>

        <div class="price-panel neon-border relative z-10 flex h-full flex-col rounded-lg bg-[rgb(var(--surface-container)_/_0.62)] p-6 lg:p-8">
          <div class="mb-2 flex items-start justify-between gap-4">
            <div>
              <h3 class="flex items-center gap-2 font-display text-[24px] font-semibold leading-tight text-foreground">
                <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 7H19M19 7L15 3M19 7L15 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M17 17H5M5 17L9 13M5 17L9 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Model Comparison
              </h3>
              <p class="mt-2 text-[14px] leading-relaxed text-muted">See how much more token capacity you get with CodeToken.</p>
            </div>
            <div class="mt-1 flex gap-1.5" aria-hidden="true">
              <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
              <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
              <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
            </div>
          </div>

          <div class="mt-6 flex-grow space-y-6">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
              <label class="flex-grow space-y-2">
                <span class="block font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.14em] text-muted">Recharge Amount</span>
                <span class="relative block">
                  <span class="absolute -inset-0.5 rounded-lg bg-gradient-to-r from-primary to-[rgb(var(--tertiary))] opacity-30 blur transition duration-500"></span>
                  <input
                    class="relative h-12 w-full rounded-lg border border-border/60 bg-[rgb(var(--surface-lowest))] px-4 font-mono text-[15px] text-foreground outline-none transition focus:border-primary focus:ring-1 focus:ring-primary"
                    type="number"
                    min="1"
                    step="1"
                    value="10"
                    data-recharge-input
                    aria-label="Recharge amount in US dollars"
                  />
                </span>
              </label>
              <button class="glow-button h-12 rounded-lg bg-gradient-to-r from-cyan-400 to-blue-600 px-6 text-[16px] font-semibold text-white transition hover:opacity-90" type="button" data-calculate-button>
                Calculate
              </button>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-5">
              <div class="space-y-4 sm:col-span-3">
                {
                  comparisonRows.map((row) => (
                    <div class="rounded-lg border border-border/35 bg-[rgb(var(--surface-lowest)_/_0.78)] p-4">
                      <div class="border-b border-border/20 pb-2 font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted/75">{row.model}</div>
                      <div class="mt-3 flex items-center justify-between text-[12px]">
                        <span class="font-mono text-muted">Official API</span>
                        <span class="font-mono text-foreground" data-official-capacity={row.officialCapacity.toString()}>
                          {(row.officialCapacity * 10).toFixed(2)}M
                        </span>
                      </div>
                      <div class="mt-3 flex items-center justify-between text-[12px]">
                        <span class="flex items-center gap-1 font-mono text-muted">
                          <svg class:list={["h-3 w-3", row.accent === "primary" ? "text-primary" : "text-[rgb(var(--tertiary))]"]} viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 2L4 14H11L10 22L20 9H13L13 2Z" fill="currentColor" />
                          </svg>
                          CodeToken
                        </span>
                        <span
                          class:list={["font-mono font-bold", row.accent === "primary" ? "glow-text text-primary" : "glow-magenta text-[rgb(var(--tertiary))]"]}
                          data-code-capacity={row.codeTokenCapacity.toString()}
                        >
                          {(row.codeTokenCapacity * 10).toFixed(2)}M
                        </span>
                      </div>
                      <div class="mt-3 flex items-center justify-between border-t border-border/20 pt-3 text-[12px]">
                        <span class="font-mono text-muted">Savings</span>
                        <span class:list={["font-mono", row.accent === "primary" ? "text-[rgb(var(--tertiary))]" : "text-primary"]}>85%</span>
                      </div>
                    </div>
                  ))
                }
              </div>

              <div class="flex flex-col justify-center sm:col-span-2">
                <div class="relative flex h-full min-h-64 flex-col justify-center overflow-hidden rounded-lg border border-primary/25 bg-[rgb(var(--surface-lowest)_/_0.82)] p-4 text-center shadow-[0_0_24px_rgba(34,211,238,0.12)]">
                  <div class="absolute left-0 top-0 h-1 w-full bg-gradient-to-r from-primary to-[rgb(var(--tertiary))]"></div>
                  <div class="mb-1 text-[10px] text-muted">Recharge Amount: $<span data-recharge-display>10.00</span></div>
                  <div class="mb-1 font-mono text-[10px] uppercase tracking-[0.12em] text-muted/70">CodeToken Cloud</div>
                  <div class="glow-text mb-3 font-display text-[32px] font-bold text-primary" data-summary-code>9.86M</div>
                  <div class="space-y-2 text-[12px]">
                    <div class="flex items-center justify-between rounded border border-border/30 bg-[rgb(var(--surface-container)_/_0.48)] px-2 py-1">
                      <span class="text-muted">Official API</span>
                      <span class="font-mono text-foreground" data-summary-official>1.48M</span>
                    </div>
                    <div class="font-semibold text-primary"><span data-summary-ratio>6.66</span>x More Capacity</div>
                    <div class="text-[rgb(var(--tertiary))]">Save about 85%</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <p class="mt-6 border-t border-border/20 pt-4 text-[10px] italic leading-relaxed text-muted/70">
            * Based on 80% input, 20% output, 90% input cache hit rate, and CodeToken pricing at 0.15x official pricing.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const formatCapacity = (value: number) => `${value.toFixed(2)}M`;

  document.querySelectorAll<HTMLElement>("[data-price-calculator]").forEach((calculator) => {
    const input = calculator.querySelector<HTMLInputElement>("[data-recharge-input]");
    const button = calculator.querySelector<HTMLButtonElement>("[data-calculate-button]");
    const rechargeDisplay = calculator.querySelector<HTMLElement>("[data-recharge-display]");
    const summaryCode = calculator.querySelector<HTMLElement>("[data-summary-code]");
    const summaryOfficial = calculator.querySelector<HTMLElement>("[data-summary-official]");
    const summaryRatio = calculator.querySelector<HTMLElement>("[data-summary-ratio]");

    if (!input || !button || !rechargeDisplay || !summaryCode || !summaryOfficial || !summaryRatio) {
      return;
    }

    const update = () => {
      const rawAmount = Number.parseFloat(input.value);
      const amount = Number.isFinite(rawAmount) && rawAmount > 0 ? rawAmount : 10;

      calculator.querySelectorAll<HTMLElement>("[data-official-capacity]").forEach((node) => {
        const perDollar = Number.parseFloat(node.dataset.officialCapacity || "0");
        node.textContent = formatCapacity(perDollar * amount);
      });

      calculator.querySelectorAll<HTMLElement>("[data-code-capacity]").forEach((node) => {
        const perDollar = Number.parseFloat(node.dataset.codeCapacity || "0");
        node.textContent = formatCapacity(perDollar * amount);
      });

      const officialPerDollar = 0.148;
      const codeTokenPerDollar = 0.986;
      rechargeDisplay.textContent = amount.toFixed(2);
      summaryOfficial.textContent = formatCapacity(officialPerDollar * amount);
      summaryCode.textContent = formatCapacity(codeTokenPerDollar * amount);
      summaryRatio.textContent = (codeTokenPerDollar / officialPerDollar).toFixed(2);
    };

    input.addEventListener("input", update);
    button.addEventListener("click", update);
    update();
  });
</script>

<style>
  .price-section {
    background:
      linear-gradient(rgb(var(--background) / 0.84), rgb(var(--background) / 0.94)),
      radial-gradient(circle at 18% 22%, rgb(var(--primary) / 0.13), transparent 26rem),
      radial-gradient(circle at 82% 68%, rgb(var(--tertiary) / 0.09), transparent 28rem);
  }

  .price-panel {
    border: 1px solid rgb(var(--border) / 0.42);
    background: linear-gradient(180deg, rgb(var(--card) / 0.82), rgb(var(--surface-lowest) / 0.78));
    box-shadow:
      0 24px 80px rgb(0 0 0 / 0.24),
      inset 0 1px 0 rgb(255 255 255 / 0.04);
    backdrop-filter: blur(18px);
  }

  .neon-border {
    box-shadow:
      0 0 0 1px rgb(var(--primary) / 0.12),
      0 0 30px rgb(var(--primary) / 0.08),
      inset 0 1px 0 rgb(255 255 255 / 0.05);
  }

  .glow-text {
    text-shadow: 0 0 16px rgb(var(--primary) / 0.64);
  }

  .glow-magenta {
    text-shadow: 0 0 16px rgb(var(--tertiary) / 0.58);
  }

  #priceBegin {
    animation: price-pulse 1.6s ease-in-out infinite;
  }

  @keyframes price-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.55;
      transform: scale(0.82);
    }
  }

  @media (max-width: 640px) {
    .price-section {
      padding-block: 72px;
    }
  }
</style>
