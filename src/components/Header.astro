---
import type { SiteCopy } from "../i18n";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const navItems = [
  { label: copy.nav.features, href: "#features" },
  { label: copy.nav.docs, href: "#docs" },
  { label: copy.nav.pricing, href: "#pricing" },
  { label: copy.nav.status, href: "#status" },
  { label: copy.nav.blog, href: "#blog" }
];
---

<header class="sticky top-0 z-20 border-b border-border/70 bg-background/86 backdrop-blur-xl">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 sm:px-6 lg:px-8">
    <Logo brandName={copy.brand.name} />

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a class="text-sm font-semibold text-muted transition hover:text-foreground" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <LanguageSwitcher label={copy.controls.language} />
      <ThemeToggle label={copy.controls.theme} />
      <a
        class="inline-flex h-10 items-center rounded-md bg-primary px-4 text-sm font-bold text-primary-foreground transition hover:brightness-110"
        href="https://api.codetoken.cloud"
        rel="noreferrer"
      >
        {copy.nav.getApiAccess}
      </a>
    </div>
  </div>
</header>
