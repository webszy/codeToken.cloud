---
import type { SiteCopy } from "../i18n";
import Logo from "./Logo.astro";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const navItems = [
  { label: copy.nav.features, href: "#features", active: true },
  { label: copy.nav.pricing, href: "#pricing", active: false },
  { label: copy.nav.radar, href: "#radar", active: false },
  { label: copy.nav.status, href: "#status", active: false }
];
---

<header class="relative z-50 w-full border-b border-border/30 bg-card/60 shadow-[0_0_18px_rgba(47,217,244,0.1)] backdrop-blur-xl">
  <div class="site-container flex h-[88px] items-center justify-between">
    <Logo brandName={copy.brand.name} />

    <nav class="hidden items-center gap-10 md:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "pb-1 text-[18px] font-medium leading-none transition-colors duration-300 hover:text-primary",
              item.active ? "border-b-2 border-primary text-primary" : "text-muted"
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-5">
      <button class="grid h-10 w-10 place-items-center text-muted transition-colors hover:text-primary" type="button" aria-label="Theme toggle placeholder">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.2 14.6A7.7 7.7 0 0 1 9.4 3.8 8.7 8.7 0 1 0 20.2 14.6Z" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        data-auth-cta
        data-auth-label-default={copy.nav.getApiAccess}
        data-auth-label-when-auth={copy.nav.dashboard}
        class="glow-button inline-flex h-12 items-center gap-2 rounded-lg bg-gradient-to-r from-cyan-400 to-blue-600 px-7 text-[17px] font-medium text-white transition hover:opacity-90"
        type="button"
      >
        <span data-auth-cta-text>{copy.nav.getApiAccess}</span>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 10H15M11 6L15 10L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</header>
