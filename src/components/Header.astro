---
import type { SiteCopy } from "../i18n";
import Logo from "./Logo.astro";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const navItems = [
  { label: copy.nav.features, href: "#features", target: "#features" },
  { label: copy.nav.pricing, href: "#pricing", target: "#priceBegin" },
  { label: copy.nav.radar, href: "#radar", target: "#radarBegin" },
  { label: copy.nav.status, href: "#status", target: "#statusBegin" }
];
---

<header class="relative z-50 w-full border-b border-border/30 bg-card/60 shadow-[0_0_18px_rgba(47,217,244,0.1)] backdrop-blur-xl">
  <div class="site-container flex h-[88px] items-center justify-between">
    <Logo brandName={copy.brand.name} />

    <nav class="hidden items-center gap-10 md:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "border-b-2 pb-1 text-[18px] font-medium leading-none transition-colors duration-300 hover:text-primary",
              item.href === "#features" ? "border-primary text-primary" : "border-transparent text-muted"
            ]}
            data-nav-link
            data-nav-target={item.target}
            href={item.href}
            aria-current={item.href === "#features" ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-5">
      <button class="grid h-10 w-10 place-items-center text-muted transition-colors hover:text-primary" type="button" aria-label="Theme toggle placeholder">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.2 14.6A7.7 7.7 0 0 1 9.4 3.8 8.7 8.7 0 1 0 20.2 14.6Z" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        data-auth-cta
        data-auth-label-default={copy.nav.getApiAccess}
        data-auth-label-when-auth={copy.nav.dashboard}
        class="glow-button inline-flex h-12 items-center gap-2 rounded-lg bg-gradient-to-r from-cyan-400 to-blue-600 px-7 text-[17px] font-medium text-white transition hover:opacity-90"
        type="button"
      >
        <span data-auth-cta-text>{copy.nav.getApiAccess}</span>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 10H15M11 6L15 10L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const activeClasses = ["border-primary", "text-primary"];
  const inactiveClasses = ["border-transparent", "text-muted"];
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));
  const scrollContainer = document.querySelector<HTMLElement>(".site-main-scroll");
  const scrollTopPadding = 20;
  const snapScrollLockMs = 850;

  const setActiveNav = (targetId: string) => {
    navLinks.forEach((link) => {
      const isActive = link.dataset.navTarget === targetId;
      link.classList.toggle(activeClasses[0], isActive);
      link.classList.toggle(activeClasses[1], isActive);
      link.classList.toggle(inactiveClasses[0], !isActive);
      link.classList.toggle(inactiveClasses[1], !isActive);

      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  if (scrollContainer && navLinks.length > 0) {
    const sections = navLinks
      .map((link) => {
        const id = link.dataset.navTarget || "";
        const element = document.querySelector<HTMLElement>(id);
        const href = link.getAttribute("href") || id;
        return element ? { id, element, href } : null;
      })
      .filter((section): section is { id: string; element: HTMLElement; href: string } => Boolean(section));

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const desktopWheelSnap = window.matchMedia("(min-width: 900px)");

    const getTargetScrollTop = (element: HTMLElement) => {
      const containerTop = scrollContainer.getBoundingClientRect().top;
      const targetTop = element.getBoundingClientRect().top;
      return scrollContainer.scrollTop + targetTop - containerTop - scrollTopPadding;
    };

    const scrollToSection = (section: { id: string; element: HTMLElement; href: string }, behavior: ScrollBehavior = "smooth") => {
      setActiveNav(section.id);
      scrollContainer.scrollTo({
        top: getTargetScrollTop(section.element),
        behavior: prefersReducedMotion.matches ? "auto" : behavior
      });
      history.replaceState(null, "", section.href);
    };

    const getClosestSectionIndex = () => {
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      sections.forEach((section, index) => {
        const distance = Math.abs(getTargetScrollTop(section.element) - scrollContainer.scrollTop);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    navLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const targetId = link.dataset.navTarget;
        const section = sections.find((item) => item.id === targetId);
        if (!section) return;

        event.preventDefault();
        scrollToSection(section);
      });
    });

    let ticking = false;
    let wheelLocked = false;

    const syncActiveFromScroll = () => {
      const containerTop = scrollContainer.getBoundingClientRect().top;
      const activationOffset = 140;
      let activeId = sections[0]?.id || "#features";

      sections.forEach((section) => {
        const top = section.element.getBoundingClientRect().top - containerTop;
        if (top <= activationOffset) {
          activeId = section.id;
        }
      });

      setActiveNav(activeId);
      ticking = false;
    };

    scrollContainer.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(syncActiveFromScroll);
      },
      { passive: true }
    );

    syncActiveFromScroll();

    scrollContainer.addEventListener(
      "wheel",
      (event) => {
        if (!desktopWheelSnap.matches || prefersReducedMotion.matches || sections.length < 2) return;
        if (Math.abs(event.deltaY) < 8) return;

        const currentIndex = getClosestSectionIndex();
        const nextIndex = event.deltaY > 0 ? Math.min(currentIndex + 1, sections.length - 1) : Math.max(currentIndex - 1, 0);

        if (nextIndex === currentIndex) return;

        event.preventDefault();

        if (wheelLocked) return;

        wheelLocked = true;
        scrollToSection(sections[nextIndex]);

        window.setTimeout(() => {
          wheelLocked = false;
        }, snapScrollLockMs);
      },
      { passive: false }
    );
  }
</script>
