<script is:inline>
  (() => {
    const LOGIN_URL = "https://api.codetoken.cloud/login";
    const DASHBOARD_URL = "https://api.codetoken.cloud/dashboard";
    const AUTH_CTA_SELECTOR = "[data-auth-cta]";

    const parseExpiry = (value) => {
      if (!value) return Number.NaN;

      const trimmed = value.trim();
      const numeric = Number(trimmed);

      if (Number.isFinite(numeric)) {
        return numeric < 1_000_000_000_000 ? numeric * 1000 : numeric;
      }

      return Date.parse(trimmed);
    };

    const hasValidSession = () => {
      try {
        const authToken = window.localStorage.getItem("auth_token");
        const expiresAt = parseExpiry(window.localStorage.getItem("token_expires_at"));

        return Boolean(authToken) && Number.isFinite(expiresAt) && expiresAt > Date.now();
      } catch {
        return false;
      }
    };

    const getAuthTargetUrl = () => (hasValidSession() ? DASHBOARD_URL : LOGIN_URL);

    const handleAuthCtaClick = () => {
      window.location.href = getAuthTargetUrl();
    };

    const updateAuthCtas = () => {
      const isAuthenticated = hasValidSession();

      document.querySelectorAll(AUTH_CTA_SELECTOR).forEach((cta) => {
        const text = cta.querySelector("[data-auth-cta-text]");
        const label = isAuthenticated ? cta.dataset.authLabelWhenAuth : cta.dataset.authLabelDefault;

        if (text && label) {
          text.textContent = label;
        }
      });
    };

    const bindAuthCtaClicks = () => {
      document.querySelectorAll(AUTH_CTA_SELECTOR).forEach((cta) => {
        if (!(cta instanceof HTMLButtonElement)) return;
        if (cta.dataset.authCtaBound === "true") return;

        cta.dataset.authCtaBound = "true";
        cta.addEventListener("click", handleAuthCtaClick);
      });
    };

    const initializeAuthCtas = () => {
      updateAuthCtas();
      bindAuthCtaClicks();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeAuthCtas, { once: true });
    } else {
      initializeAuthCtas();
    }

    window.addEventListener("storage", updateAuthCtas);
  })();
</script>
