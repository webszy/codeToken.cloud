---
import type { SiteCopy } from "../i18n";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
const { radar } = copy;
const radarDefaultThanks = radar.thanksPrefix ? `${radar.thanksPrefix} codexradar` : "";

const scoreCards = [
  {
    model: "GPT-5.5 xhigh",
    score: "-",
    color: "green",
    glow: "rgba(74,222,128,0.3)"
  },
  {
    model: "GPT-5.5 high",
    score: "-",
    color: "blue",
    glow: "rgba(96,165,250,0.3)"
  },
  {
    model: "GPT-5.5 medium",
    score: "-",
    color: "orange",
    glow: "rgba(251,146,60,0.3)"
  },
  {
    model: "GPT-5.4 xhigh",
    score: "-",
    color: "purple",
    glow: "rgba(192,132,252,0.3)"
  },
  {
    model: "GPT-5.4 high",
    score: "-",
    color: "red",
    glow: "rgba(248,113,113,0.3)"
  }
];

const metricRows = [
  {
    model: "GPT-5.5 high",
    iq: "-",
    pass: "-",
    cost: "-",
    costDetail: "",
    time: "-",
    tokens: "-",
    cacheHit: "-",
    color: "blue"
  },
  {
    model: "GPT-5.5 medium",
    iq: "-",
    pass: "-",
    cost: "-",
    costDetail: "",
    time: "-",
    tokens: "-",
    cacheHit: "-",
    color: "orange"
  },
  {
    model: "GPT-5.5 xhigh",
    iq: "-",
    pass: "-",
    cost: "-",
    costDetail: "",
    time: "-",
    tokens: "-",
    cacheHit: "-",
    color: "green"
  },
  {
    model: "GPT-5.4 high",
    iq: "-",
    pass: "-",
    cost: "-",
    costDetail: "",
    time: "-",
    tokens: "-",
    cacheHit: "-",
    color: "red"
  },
  {
    model: "GPT-5.4 xhigh",
    iq: "-",
    pass: "-",
    cost: "-",
    costDetail: "",
    time: "-",
    tokens: "-",
    cacheHit: "-",
    color: "purple"
  }
];

const colorClasses = {
  green: {
    text: "text-green-400",
    dot: "bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.6)]",
    hover: "hover:border-green-400/50",
    veil: "bg-green-500/5"
  },
  blue: {
    text: "text-blue-400",
    dot: "bg-blue-400 shadow-[0_0_8px_rgba(96,165,250,0.6)]",
    hover: "hover:border-blue-400/50",
    veil: "bg-blue-500/5"
  },
  orange: {
    text: "text-orange-400",
    dot: "bg-orange-400 shadow-[0_0_8px_rgba(251,146,60,0.6)]",
    hover: "hover:border-orange-400/50",
    veil: "bg-orange-500/5"
  },
  purple: {
    text: "text-purple-400",
    dot: "bg-purple-400 shadow-[0_0_8px_rgba(192,132,252,0.6)]",
    hover: "hover:border-purple-400/50",
    veil: "bg-purple-500/5"
  },
  red: {
    text: "text-red-400",
    dot: "bg-red-400 shadow-[0_0_8px_rgba(248,113,113,0.6)]",
    hover: "hover:border-red-400/50",
    veil: "bg-red-500/5"
  }
} as const;
---

<section
  id="radar"
  class="radar-section relative z-10 overflow-hidden py-24 md:py-28"
  data-radar-copy
  data-last-updated-prefix={radar.runtime.lastUpdatedPrefix}
  data-not-available={radar.runtime.notAvailable}
  data-unknown={radar.runtime.unknown}
  data-thanks-prefix={radar.thanksPrefix}
>
  <div class="pointer-events-none absolute right-[14%] top-[12%] h-72 w-72 rounded-full bg-primary/10 blur-[110px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-[16%] left-[10%] h-72 w-72 rounded-full bg-[rgb(var(--tertiary)_/_0.08)] blur-[120px]" aria-hidden="true"></div>

  <div class="site-container relative z-10">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <div id="radarBegin" class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.18em] text-primary">
          <span class="h-2 w-2 rounded-full bg-primary shadow-[0_0_10px_rgba(138,235,255,0.9)]"></span>
          {radar.badge}
        </div>
      <h2 class="headline-gradient pb-2 font-display text-[38px] font-bold leading-[1.12] tracking-normal md:text-[56px]">
        {radar.title}
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-[18px] leading-[1.7] text-muted">
        {radar.description}
      </p>
    </div>

    <div class="mb-6 flex w-full items-center justify-between gap-4 border-b border-border/40 pb-px" data-radar-tabs>
      <div class="flex min-w-0">
        <button class="min-h-11 border-b-2 border-primary bg-primary/10 px-6 py-3 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.14em] text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" type="button" data-radar-source="codex" aria-pressed="true">
          {radar.tabs.codex}
        </button>
        <button class="min-h-11 border-b-2 border-transparent px-6 py-3 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.14em] text-muted transition hover:bg-[rgb(var(--surface-container)_/_0.28)] hover:text-foreground focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" type="button" data-radar-source="claude" aria-pressed="false">
          {radar.tabs.claude}
        </button>
      </div>
      <div class="shrink-0 pb-3 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.14em] text-muted" data-radar-updated>
        {radar.runtime.lastUpdatedPrefix}-
      </div>
    </div>

    <div class="mb-6 grid grid-cols-2 gap-4 md:grid-cols-5 md:gap-6" data-radar-score-grid>
      {
        scoreCards.map((card) => {
          const classes = colorClasses[card.color as keyof typeof colorClasses];

          return (
            <article class:list={["radar-card group relative min-h-[96px] overflow-hidden rounded-lg border border-border/50 bg-[rgb(var(--card)_/_0.62)] px-4 pb-2 pt-6 transition-all duration-300 md:min-h-0 md:p-6", classes.hover]}>
              <div class:list={["absolute inset-0 opacity-0 transition-opacity group-hover:opacity-100", classes.veil]}></div>
              <div class="relative z-10 mb-2 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.12em] text-muted md:mb-5">{card.model}</div>
              <div class:list={["relative z-10 font-display text-[40px] font-bold leading-none tracking-normal md:text-[56px]", classes.text]} style={`text-shadow: 0 0 15px ${card.glow};`}>
                {card.score}
              </div>
              <div class="absolute right-4 top-4 flex gap-1" aria-hidden="true">
                <span class:list={["h-1.5 w-1.5 rounded-full opacity-50", classes.dot]}></span>
                <span class:list={["h-1.5 w-1.5 rounded-full opacity-50", classes.dot]}></span>
                <span class:list={["h-1.5 w-1.5 rounded-full opacity-50", classes.dot]}></span>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mb-[6px] flex justify-end">
      <a class="radar-thanks-link" href="https://codexradar.com/" target="_blank" rel="noreferrer" data-radar-thanks-link>{radarDefaultThanks}</a>
    </div>

    <section class="radar-table overflow-hidden rounded-lg border border-primary/20 bg-[rgb(var(--surface-container)_/_0.4)] shadow-[0_0_30px_rgba(47,217,244,0.05)] backdrop-blur-2xl" aria-label={radar.tableAriaLabel}>
      <div class="overflow-x-auto">
        <table class="min-w-[900px] w-full whitespace-nowrap text-left font-mono text-[14px] leading-[1.5]">
          <thead class="border-b border-border/40 bg-[rgb(var(--surface-container)_/_0.32)] text-[rgb(var(--tertiary))]">
            <tr>
              <th class="px-6 py-4 font-medium">{radar.table.model}</th>
              <th class="px-6 py-4 font-medium">{radar.table.iq}</th>
              <th class="px-6 py-4 font-medium">{radar.table.pass}</th>
              <th class="px-6 py-4 font-medium">{radar.table.cost} <span class="text-xs text-muted/60">{radar.table.costUnit}</span></th>
              <th class="px-6 py-4 font-medium">{radar.table.time} <span class="text-xs text-muted/60">{radar.table.timeUnit}</span></th>
              <th class="px-6 py-4 font-medium">{radar.table.tokens} <span class="text-xs text-muted/60">{radar.table.tokensUnit}</span></th>
              <th class="px-6 py-4 font-medium">{radar.table.cacheHit} <span class="text-xs text-muted/60">{radar.table.cacheHitUnit}</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/20 text-foreground" data-radar-metrics-body>
            {
              metricRows.map((row, index) => {
                const classes = colorClasses[row.color as keyof typeof colorClasses];

                return (
                  <tr class:list={["group transition-colors hover:bg-primary/5", index % 2 === 1 && "bg-[rgb(var(--surface-container)_/_0.12)]"]}>
                    <td class="flex items-center gap-3 px-6 py-4">
                      <span class:list={["h-2 w-2 rounded-full", classes.dot]}></span>
                      {row.model}
                    </td>
                    <td class:list={["px-6 py-4 font-bold transition-colors group-hover:text-primary", classes.text]}>{row.iq}</td>
                    <td class="px-6 py-4 text-green-400/90">{row.pass}</td>
                    <td class="px-6 py-4">
                      {row.cost} <span class="ml-1 text-xs text-muted">{row.costDetail}</span>
                    </td>
                    <td class="px-6 py-4">{row.time}</td>
                    <td class="px-6 py-4">{row.tokens}</td>
                    <td class="px-6 py-4 text-green-400/90">{row.cacheHit}</td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </section>
  </div>
</section>

<script is:inline>
  const radarWindow = window;
  const radarCopyNode = document.querySelector("[data-radar-copy]");
  const radarCopyDataset = radarCopyNode instanceof HTMLElement ? radarCopyNode.dataset : {};
  const getRadarCopy = (key) => (Object.prototype.hasOwnProperty.call(radarCopyDataset, key) ? radarCopyDataset[key] || "" : "");

  const radarAccentMap = {
    green: {
      text: "text-green-400",
      dot: "bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.6)]",
      hover: "hover:border-green-400/50",
      veil: "bg-green-500/5",
      glow: "rgba(74,222,128,0.3)"
    },
    blue: {
      text: "text-blue-400",
      dot: "bg-blue-400 shadow-[0_0_8px_rgba(96,165,250,0.6)]",
      hover: "hover:border-blue-400/50",
      veil: "bg-blue-500/5",
      glow: "rgba(96,165,250,0.3)"
    },
    amber: {
      text: "text-orange-400",
      dot: "bg-orange-400 shadow-[0_0_8px_rgba(251,146,60,0.6)]",
      hover: "hover:border-orange-400/50",
      veil: "bg-orange-500/5",
      glow: "rgba(251,146,60,0.3)"
    },
    orange: {
      text: "text-orange-400",
      dot: "bg-orange-400 shadow-[0_0_8px_rgba(251,146,60,0.6)]",
      hover: "hover:border-orange-400/50",
      veil: "bg-orange-500/5",
      glow: "rgba(251,146,60,0.3)"
    },
    purple: {
      text: "text-purple-400",
      dot: "bg-purple-400 shadow-[0_0_8px_rgba(192,132,252,0.6)]",
      hover: "hover:border-purple-400/50",
      veil: "bg-purple-500/5",
      glow: "rgba(192,132,252,0.3)"
    },
    red: {
      text: "text-red-400",
      dot: "bg-red-400 shadow-[0_0_8px_rgba(248,113,113,0.6)]",
      hover: "hover:border-red-400/50",
      veil: "bg-red-500/5",
      glow: "rgba(248,113,113,0.3)"
    }
  };

  let activeRadarSource = "codex";

  const getRadarAccent = (accent) => radarAccentMap[accent || ""] || radarAccentMap.blue;

  const formatRadarNumber = (value, digits = 1) => {
    if (typeof value !== "number" || !Number.isFinite(value)) return getRadarCopy("notAvailable");
    const formatted = value.toFixed(digits);
    return digits === 0 ? formatted : formatted.replace(/\.?0+$/, "");
  };

  const formatPassRate = (passed, total) => {
    if (typeof passed !== "number" || typeof total !== "number" || !Number.isFinite(passed) || !Number.isFinite(total) || total <= 0) {
      return getRadarCopy("notAvailable");
    }
    return `${((passed / total) * 100).toFixed(1).replace(/\.?0+$/, "")}%`;
  };

  const padRadarDatePart = (value) => String(value).padStart(2, "0");

  const formatRadarUpdatedText = (value) => {
    if (typeof value !== "string" || value.trim() === "") return "-";

    const chineseMatch = value.match(/(\d{1,2})月(\d{1,2})日\s*(\d{1,2}):(\d{2})/);
    if (chineseMatch) {
      return `${padRadarDatePart(chineseMatch[1])}/${padRadarDatePart(chineseMatch[2])} ${padRadarDatePart(chineseMatch[3])}:${chineseMatch[4]}`;
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";

    return `${padRadarDatePart(date.getMonth() + 1)}/${padRadarDatePart(date.getDate())} ${padRadarDatePart(date.getHours())}:${padRadarDatePart(date.getMinutes())}`;
  };

  const formatRadarThanksText = (url) => {
    const thanksPrefix = getRadarCopy("thanksPrefix");
    if (typeof url !== "string" || url.trim() === "") return thanksPrefix;

    try {
      const hostname = new URL(url).hostname.replace(/^www\./, "");
      const domain = hostname.split(".")[0];
      return domain ? `${thanksPrefix} ${domain}`.trim() : thanksPrefix;
    } catch {
      return thanksPrefix;
    }
  };

  const createRadarCell = (text, className) => {
    const cell = document.createElement("td");
    cell.className = className;
    cell.textContent = text;
    return cell;
  };

  const renderRadar = (feed) => {
    const radar = feed?.aiRadar?.[activeRadarSource];
    if (!radar) return;

    const scoreGrid = document.querySelector("[data-radar-score-grid]");
    const metricsBody = document.querySelector("[data-radar-metrics-body]");
    const updatedNode = document.querySelector("[data-radar-updated]");
    const thanksLink = document.querySelector("[data-radar-thanks-link]");
    if (!scoreGrid || !metricsBody) return;

    if (updatedNode) {
      updatedNode.textContent = `${getRadarCopy("lastUpdatedPrefix")}${formatRadarUpdatedText(radar.updatedText)}`;
    }

    if (thanksLink && typeof radar.url === "string" && radar.url.trim() !== "") {
      thanksLink.href = radar.url;
      thanksLink.textContent = formatRadarThanksText(radar.url);
    }

    const scoreCards = radar.iqCards?.filter((card) => card.label) || [];
    if (scoreCards.length > 0) {
      scoreGrid.replaceChildren(
        ...scoreCards.map((card) => {
          const accent = getRadarAccent(card.accent);
          const article = document.createElement("article");
          article.className = `radar-card group relative min-h-[96px] overflow-hidden rounded-lg border border-border/50 bg-[rgb(var(--card)_/_0.62)] px-4 pb-2 pt-6 transition-all duration-300 md:min-h-0 md:p-6 ${accent.hover}`;

          const veil = document.createElement("div");
          veil.className = `absolute inset-0 opacity-0 transition-opacity group-hover:opacity-100 ${accent.veil}`;

          const label = document.createElement("div");
          label.className = "relative z-10 mb-2 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.12em] text-muted md:mb-5";
          label.textContent = card.label || getRadarCopy("unknown");

          const score = document.createElement("div");
          score.className = `relative z-10 font-display text-[40px] font-bold leading-none tracking-normal md:text-[56px] ${accent.text}`;
          score.style.textShadow = `0 0 15px ${accent.glow}`;
          score.textContent = formatRadarNumber(card.iq, 0);

          const dots = document.createElement("div");
          dots.className = "absolute right-4 top-4 flex gap-1";
          dots.setAttribute("aria-hidden", "true");
          for (let index = 0; index < 3; index += 1) {
            const dot = document.createElement("span");
            dot.className = `h-1.5 w-1.5 rounded-full opacity-50 ${accent.dot}`;
            dots.append(dot);
          }

          article.append(veil, label, score, dots);
          return article;
        })
      );
    }

    const rows = radar.multiModelMetrics?.models?.filter((row) => row.label) || [];
    if (rows.length > 0) {
      metricsBody.replaceChildren(
        ...rows.map((row, index) => {
          const accent = getRadarAccent(row.accent);
          const tr = document.createElement("tr");
          tr.className = `group transition-colors hover:bg-primary/5 ${index % 2 === 1 ? "bg-[rgb(var(--surface-container)_/_0.12)]" : ""}`;

          const modelCell = document.createElement("td");
          modelCell.className = "flex items-center gap-3 px-6 py-4";
          const dot = document.createElement("span");
          dot.className = `h-2 w-2 rounded-full ${accent.dot}`;
          modelCell.append(dot, document.createTextNode(row.label || getRadarCopy("unknown")));

          tr.append(
            modelCell,
            createRadarCell(formatRadarNumber(row.iq, 0), `px-6 py-4 font-bold transition-colors group-hover:text-primary ${accent.text}`),
            createRadarCell(formatPassRate(row.passed, row.total), "px-6 py-4 text-green-400/90"),
            createRadarCell(`$${formatRadarNumber(row.costUsd, 2)}`, "px-6 py-4"),
            createRadarCell(formatRadarNumber(row.durationHours, 1), "px-6 py-4"),
            createRadarCell(`${formatRadarNumber(row.totalTokensMillion, 2)}M`, "px-6 py-4"),
            createRadarCell(`${formatRadarNumber(row.cacheHitRate, 1)}%`, "px-6 py-4 text-green-400/90")
          );

          return tr;
        })
      );
    }
  };

  const updateRadarTabs = () => {
    document.querySelectorAll("[data-radar-source]").forEach((button) => {
      const isActive = button.dataset.radarSource === activeRadarSource;
      button.setAttribute("aria-pressed", String(isActive));
      button.classList.toggle("border-primary", isActive);
      button.classList.toggle("bg-primary/10", isActive);
      button.classList.toggle("text-primary", isActive);
      button.classList.toggle("border-transparent", !isActive);
      button.classList.toggle("text-muted", !isActive);
    });
  };

  document.querySelectorAll("[data-radar-source]").forEach((button) => {
    button.addEventListener("click", () => {
      const nextSource = button.dataset.radarSource;
      if (nextSource !== "codex" && nextSource !== "claude") return;
      activeRadarSource = nextSource;
      updateRadarTabs();
      renderRadar(radarWindow.CODETOKEN_FEED);
    });
  });

  updateRadarTabs();
  renderRadar(radarWindow.CODETOKEN_FEED);
  window.addEventListener("codetoken-feed-ready", (event) => {
    renderRadar(event.detail);
  });
  window.addEventListener("load", () => {
    renderRadar(radarWindow.CODETOKEN_FEED);
  });
</script>

<style>
  .radar-section {
    background:
      linear-gradient(rgb(var(--background) / 0.9), rgb(var(--background) / 0.96)),
      radial-gradient(circle at 72% 18%, rgb(var(--primary) / 0.1), transparent 24rem),
      radial-gradient(circle at 18% 78%, rgb(var(--tertiary) / 0.07), transparent 26rem);
  }

  :global([data-theme="light"]) .radar-section {
    background:
      linear-gradient(180deg, rgba(246, 250, 253, 0.9), rgba(255, 255, 255, 0.96)),
      radial-gradient(circle at 72% 18%, rgba(34, 211, 238, 0.1), transparent 24rem),
      radial-gradient(circle at 18% 78%, rgba(124, 58, 237, 0.07), transparent 26rem);
  }

  .radar-section::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    opacity: 0.42;
    background-image: url("data:image/svg+xml,%3Csvg width='72' height='62' viewBox='0 0 72 62' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M36 1L70 19.5V42.5L36 61L2 42.5V19.5Z' fill='%238aebff' fill-opacity='0.035'/%3E%3C/svg%3E");
    background-size: 72px 62px;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 82%, transparent 100%);
  }

  :global([data-theme="light"]) .radar-section::before {
    opacity: 0.24;
  }

  .radar-card,
  .radar-table {
    box-shadow:
      0 24px 80px rgb(0 0 0 / 0.22),
      inset 0 1px 0 rgb(255 255 255 / 0.04);
    backdrop-filter: blur(18px);
  }

  :global([data-theme="light"]) .radar-card,
  :global([data-theme="light"]) .radar-table {
    background: rgba(255, 255, 255, 0.86);
    border-color: rgba(148, 163, 184, 0.28);
    box-shadow:
      0 18px 50px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  :global([data-theme="light"]) .radar-table thead {
    background: #eef6fc;
    color: #6d28d9;
  }

  :global([data-theme="light"]) .radar-table tbody tr:hover {
    background: rgba(2, 132, 199, 0.055);
  }

  .radar-thanks-link {
    align-items: center;
    color: rgba(180, 210, 230, 0.55);
    display: inline-flex;
    font-size: 11px;
    letter-spacing: 0.14em;
    margin-bottom: 6px;
    min-height: 44px;
    text-transform: uppercase;
  }

  :global([data-theme="light"]) .radar-thanks-link {
    color: rgba(82, 99, 122, 0.72);
  }

  @media (max-width: 640px) {
    .radar-section [data-radar-tabs] {
      align-items: flex-start;
    }

    .radar-section [data-radar-updated] {
      flex: 0 0 9.5rem;
      line-height: 1.35;
      text-align: center;
      white-space: normal;
    }
  }
</style>
