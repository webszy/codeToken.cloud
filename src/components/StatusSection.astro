---
import type { SiteCopy } from "../i18n";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
const { status } = copy;

type StatusTone = "cyan" | "blue" | "purple" | "green" | "amber";

type StatusCard = {
  key: string;
  label: string;
  value: string;
  unit?: string;
  detail: string;
  iconPath: string;
  tone: StatusTone;
};

const statusCards: StatusCard[] = [
  {
    key: "server-load",
    label: status.cards.serverLoad,
    value: "-",
    detail: "-",
    iconPath: "M6 8H18M8 4V8M16 4V8M8 16V20M16 16V20M6 16H18M8 8V16M16 8V16M10.5 11H13.5V13H10.5V11Z",
    tone: "cyan"
  },
  {
    key: "requests",
    label: status.cards.requests,
    value: "-",
    detail: "-",
    iconPath: "M7 7H19M19 7L15 3M19 7L15 11M17 17H5M5 17L9 13M5 17L9 21",
    tone: "blue"
  },
  {
    key: "tokens",
    label: status.cards.tokens,
    value: "-",
    detail: "-",
    iconPath: "M12 3L19 7V17L12 21L5 17V7L12 3ZM12 7L8.5 9V15L12 17L15.5 15V9L12 7Z",
    tone: "purple"
  },
  {
    key: "success-rate",
    label: status.cards.successRate,
    value: "-",
    detail: "-",
    iconPath: "M20 6L9 17L4 12M21 12A9 9 0 1 1 12 3",
    tone: "green"
  },
  {
    key: "avg-qps",
    label: status.cards.avgQps,
    value: "-",
    detail: "-",
    iconPath: "M4 14A8 8 0 0 1 20 14M12 14L16 9M7 18H17",
    tone: "cyan"
  },
  {
    key: "avg-tps",
    label: status.cards.avgTps,
    value: "-",
    detail: "-",
    iconPath: "M13 2L4 14H11L10 22L20 9H13V2Z",
    tone: "blue"
  },
  {
    key: "ttft",
    label: status.cards.ttft,
    value: "-",
    detail: "-",
    iconPath: "M12 7V12L15 15M12 3A9 9 0 1 0 21 12A9 9 0 0 0 12 3Z",
    tone: "amber"
  },
  {
    key: "upstream",
    label: status.cards.upstream,
    value: "-",
    detail: "-",
    iconPath: "M12 3A9 9 0 1 0 21 12A9 9 0 0 0 12 3ZM3.6 12H20.4M12 3C14.3 5.4 15.4 8.4 15.4 12C15.4 15.6 14.3 18.6 12 21M12 3C9.7 5.4 8.6 8.4 8.6 12C8.6 15.6 9.7 18.6 12 21",
    tone: "green"
  }
];

const toneClasses = {
  cyan: {
    border: "border-primary/30",
    icon: "text-primary",
    iconBox: "border-primary/20 bg-primary/10",
    value: "text-primary",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(47,217,244,0.15)]"
  },
  blue: {
    border: "border-blue-500/40",
    icon: "text-blue-400",
    iconBox: "border-blue-500/30 bg-blue-500/10",
    value: "text-blue-200",
    detail: "text-blue-400",
    shadow: "hover:shadow-[0_0_25px_rgba(5,102,217,0.15)]"
  },
  purple: {
    border: "border-[rgb(var(--tertiary)_/_0.4)]",
    icon: "text-[rgb(var(--tertiary))]",
    iconBox: "border-[rgb(var(--tertiary)_/_0.3)] bg-[rgb(var(--tertiary)_/_0.1)]",
    value: "text-[rgb(var(--tertiary))]",
    detail: "text-[rgb(var(--tertiary)_/_0.82)]",
    shadow: "hover:shadow-[0_0_25px_rgba(217,176,255,0.15)]"
  },
  green: {
    border: "border-cyan-400/35",
    icon: "text-cyan-300",
    iconBox: "border-cyan-400/30 bg-cyan-400/10",
    value: "text-cyan-300",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(34,211,238,0.15)]"
  },
  amber: {
    border: "border-amber-400/30",
    icon: "text-amber-400",
    iconBox: "border-amber-400/20 bg-amber-400/10",
    value: "text-amber-400",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(251,191,36,0.15)]"
  }
} as const;
---

<section
  id="status"
  class="status-section relative z-10 overflow-hidden py-24 md:py-28"
  data-status-copy
  data-not-available={status.runtime.notAvailable}
  data-last-updated-unavailable={status.runtime.lastUpdatedUnavailable}
  data-last-updated-prefix={status.runtime.lastUpdatedPrefix}
  data-data-window-live={status.runtime.dataWindowLive}
  data-cpu={status.runtime.cpu}
  data-mem={status.runtime.mem}
  data-load={status.runtime.load}
  data-request-count-total={status.runtime.requestCountTotal}
  data-today={status.runtime.today}
  data-error={status.runtime.error}
  data-req-per-second-live-average={status.runtime.reqPerSecondLiveAverage}
  data-tokens-per-second-live-average={status.runtime.tokensPerSecondLiveAverage}
  data-avg-first-response={status.runtime.avgFirstResponse}
  data-healthy={status.runtime.healthy}
  data-degraded={status.runtime.degraded}
  data-health-score={status.runtime.healthScore}
>
  <div class="pointer-events-none absolute left-[12%] top-[14%] h-72 w-72 rounded-full bg-primary/10 blur-[110px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-[14%] right-[14%] h-80 w-80 rounded-full bg-[rgb(var(--tertiary)_/_0.08)] blur-[130px]" aria-hidden="true"></div>

  <div class="site-container relative z-10">
    <header class="mx-auto mb-12 flex max-w-3xl flex-col items-center gap-6 text-center">
      <div id="statusBegin" class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.18em] text-primary">
        <span class="h-2 w-2 rounded-full bg-primary shadow-[0_0_10px_rgba(138,235,255,0.9)]"></span>
        {status.badge}
      </div>
      <div>
        <h2 class="headline-gradient font-display text-[34px] font-bold leading-[1.12] tracking-normal md:text-[44px]">
          {status.title}
        </h2>
        <p class="mx-auto mt-2 max-w-2xl text-[18px] leading-[1.6] text-muted">{status.description}</p>
      </div>
    </header>

    <div class="mb-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        statusCards.map((card) => {
          const classes = toneClasses[card.tone as keyof typeof toneClasses];

          return (
            <article class:list={["status-card group flex flex-col gap-4 rounded-lg border p-6 transition-shadow duration-300", classes.border, classes.shadow]} data-status-card={card.key} data-status-tone={card.tone}>
              <div class="flex items-start justify-between gap-4">
                <div class:list={["flex items-center gap-2", classes.icon]}>
                  <div class:list={["flex h-8 w-8 items-center justify-center rounded-lg border", classes.iconBox]}>
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                      <path d={card.iconPath} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </div>
                  <span class="font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.12em] text-foreground" data-status-label>{card.label}</span>
                </div>
                <svg class="h-4 w-4 shrink-0 text-muted/45 transition group-hover:text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 17V11M12 7.25V7M21 12A9 9 0 1 1 3 12A9 9 0 0 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </div>

              <div>
                <div class:list={["font-display text-[42px] font-bold leading-none tracking-normal transition-colors", classes.value]}>
                  <span data-status-value>{card.value}</span>
                  <span class="text-[28px]" data-status-unit>{card.unit ?? ""}</span>
                </div>
                <div class:list={["mt-3 font-mono text-[14px] leading-[1.5]", classes.detail]} data-status-detail>{card.detail}</div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="status-card flex flex-col items-center justify-between gap-4 rounded-lg border border-border/35 px-6 py-4 md:flex-row">
      <div class="flex items-center gap-3 font-mono text-[14px] leading-[1.5] text-muted">
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 17V11M12 7.25V7M21 12A9 9 0 1 1 3 12A9 9 0 0 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span data-status-updated>-</span>
      </div>
      <div class="flex items-center gap-2" data-status-dot-sequence aria-label={status.samplePointsLabel}>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
      </div>
    </div>
  </div>
</section>

<script>
  type CodeTokenStatusOverview = {
    request_count_total?: number;
    cpu_usage_percent?: number;
    memory_usage_percent?: number;
    error_rate?: number;
    success_rate?: number;
    qps_avg?: number;
    tps_avg?: number;
    health_score?: number;
    ttft_avg_ms?: number | null;
    load_avg?: number[];
    today_tokens?: string;
    total_tokens?: string;
  };

  type StatusCodeTokenFeed = {
    generatedAt?: string;
    sub2api?: {
      available?: boolean;
      fetchedAt?: string;
      overview?: CodeTokenStatusOverview;
    };
  };

  const feedWindow = window as Window & { CODETOKEN_FEED?: StatusCodeTokenFeed };
  const statusCopyNode = document.querySelector<HTMLElement>("[data-status-copy]");
  const statusCopyDataset = statusCopyNode?.dataset ?? {};
  const getStatusCopy = (key: string) => (Object.prototype.hasOwnProperty.call(statusCopyDataset, key) ? statusCopyDataset[key] ?? "" : "");

  const formatCompactNumber = (value: number | undefined) =>
    typeof value === "number" && Number.isFinite(value)
      ? new Intl.NumberFormat("en", { maximumFractionDigits: 2 }).format(value)
      : getStatusCopy("notAvailable");

  const formatRequestCountTotal = (value: number | undefined) => (typeof value === "number" && Number.isFinite(value) ? String(value) : "-");

  const formatStatusPercent = (value: number | undefined) => {
    if (typeof value !== "number" || !Number.isFinite(value)) return getStatusCopy("notAvailable");
    const percent = value <= 1 ? value * 100 : value;
    return percent.toFixed(percent >= 99 ? 2 : 1).replace(/\.?0+$/, "");
  };

  const splitValueUnit = (rawValue: string | undefined, fallback = getStatusCopy("notAvailable")) => {
    const value = rawValue || fallback;
    const match = value.match(/^([\d.,]+)\s*([a-zA-Z]+)?$/);
    return {
      value: match?.[1] || value,
      unit: match?.[2] || ""
    };
  };

  const formatStatusTimestamp = (value: string | undefined) => {
    const unavailable = getStatusCopy("lastUpdatedUnavailable");
    const liveWindow = getStatusCopy("dataWindowLive");
    if (!value) return `${unavailable} · ${liveWindow}`;
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return `${unavailable} · ${liveWindow}`;
    return `${getStatusCopy("lastUpdatedPrefix")} ${new Intl.DateTimeFormat("en", {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit"
    }).format(date)} · ${liveWindow}`;
  };

  const setStatusCard = (key: string, value: string, unit: string, detail: string) => {
    const card = document.querySelector<HTMLElement>(`[data-status-card="${key}"]`);
    const valueNode = card?.querySelector<HTMLElement>("[data-status-value]");
    const unitNode = card?.querySelector<HTMLElement>("[data-status-unit]");
    const detailNode = card?.querySelector<HTMLElement>("[data-status-detail]");

    if (!card || !valueNode || !unitNode || !detailNode) return;

    valueNode.textContent = value;
    unitNode.textContent = unit;
    detailNode.textContent = detail;
  };

  const renderStatusFeed = (feed: StatusCodeTokenFeed | undefined) => {
    const sub2api = feed?.sub2api;
    const overview = sub2api?.overview;
    if (!sub2api?.available || !overview) return;

    const loadAverage =
      Array.isArray(overview.load_avg) && overview.load_avg.length > 0 ? overview.load_avg.join(" / ") : getStatusCopy("notAvailable");
    const totalTokens = splitValueUnit(overview.total_tokens);
    const ttftSeconds =
      typeof overview.ttft_avg_ms === "number" && Number.isFinite(overview.ttft_avg_ms) ? (overview.ttft_avg_ms / 1000).toFixed(2) : getStatusCopy("notAvailable");

    setStatusCard(
      "server-load",
      `${getStatusCopy("cpu")} ${formatStatusPercent(overview.cpu_usage_percent)}`,
      "%",
      `${getStatusCopy("mem")} ${formatStatusPercent(overview.memory_usage_percent)}% · ${getStatusCopy("load")} ${loadAverage}`
    );
    setStatusCard("requests", formatRequestCountTotal(overview.request_count_total), "", "");
    setStatusCard(
      "tokens",
      totalTokens.value,
      totalTokens.unit,
      `${overview.today_tokens || getStatusCopy("notAvailable")} ${getStatusCopy("today")}`
    );
    setStatusCard("success-rate", formatStatusPercent(overview.success_rate), "%", `${getStatusCopy("error")} ${formatStatusPercent(overview.error_rate)}%`);
    setStatusCard("avg-qps", formatCompactNumber(overview.qps_avg), "", getStatusCopy("reqPerSecondLiveAverage"));
    setStatusCard("avg-tps", formatCompactNumber(overview.tps_avg), "", getStatusCopy("tokensPerSecondLiveAverage"));
    setStatusCard("ttft", ttftSeconds, ttftSeconds === getStatusCopy("notAvailable") ? "" : "s", getStatusCopy("avgFirstResponse"));
    setStatusCard(
      "upstream",
      overview.health_score && overview.health_score >= 90 ? getStatusCopy("healthy") : getStatusCopy("degraded"),
      "",
      `${overview.health_score ?? getStatusCopy("notAvailable")}/100 ${getStatusCopy("healthScore")}`
    );

    const updatedNode = document.querySelector<HTMLElement>("[data-status-updated]");
    if (updatedNode) {
      updatedNode.textContent = formatStatusTimestamp(sub2api.fetchedAt || feed?.generatedAt);
    }
  };

  renderStatusFeed(feedWindow.CODETOKEN_FEED);
  window.addEventListener("codetoken-feed-ready", (event) => {
    renderStatusFeed((event as CustomEvent<StatusCodeTokenFeed>).detail);
  });

  const statusDotSequences = document.querySelectorAll<HTMLElement>("[data-status-dot-sequence]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const sequence = [0, 1, 2, 3, 4, 3, 2, 1];

  statusDotSequences.forEach((container) => {
    const dots = Array.from(container.querySelectorAll<HTMLElement>(".status-sequence-dot"));
    if (dots.length === 0) return;

    let step = 0;

    const setActiveDot = (index: number) => {
      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("is-active", dotIndex === index);
      });
    };

    setActiveDot(0);

    if (reducedMotion.matches) return;

    window.setInterval(() => {
      step = (step + 1) % sequence.length;
      setActiveDot(sequence[step]);
    }, 420);
  });
</script>

<style>
  .status-section {
    background:
      linear-gradient(rgb(var(--background) / 0.9), rgb(var(--background) / 0.96)),
      radial-gradient(circle at 20% 20%, rgb(var(--primary) / 0.1), transparent 24rem),
      radial-gradient(circle at 82% 74%, rgb(var(--tertiary) / 0.07), transparent 26rem);
  }

  :global([data-theme="light"]) .status-section {
    background:
      linear-gradient(180deg, rgba(246, 250, 253, 0.9), rgba(255, 255, 255, 0.96)),
      radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.1), transparent 24rem),
      radial-gradient(circle at 82% 74%, rgba(124, 58, 237, 0.07), transparent 26rem);
  }

  .status-card {
    background: linear-gradient(180deg, rgb(var(--surface-container) / 0.78), rgb(var(--surface-lowest) / 0.94));
    box-shadow:
      0 24px 80px rgb(0 0 0 / 0.22),
      inset 0 1px 0 rgb(255 255 255 / 0.04);
    backdrop-filter: blur(20px);
  }

  :global([data-theme="light"]) .status-card {
    background: rgba(255, 255, 255, 0.86);
    border-color: rgba(148, 163, 184, 0.28);
    box-shadow:
      0 18px 50px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  :global([data-theme="light"]) .status-card[data-status-tone="cyan"] {
    border-color: rgba(103, 232, 249, 0.62);
  }

  :global([data-theme="light"]) .status-card[data-status-tone="blue"] {
    border-color: rgba(147, 197, 253, 0.62);
  }

  :global([data-theme="light"]) .status-card[data-status-tone="purple"] {
    border-color: rgba(216, 180, 254, 0.68);
  }

  :global([data-theme="light"]) .status-card[data-status-tone="green"] {
    border-color: rgba(134, 239, 172, 0.68);
  }

  :global([data-theme="light"]) .status-card[data-status-tone="amber"] {
    border-color: rgba(252, 211, 77, 0.68);
  }

  .status-sequence-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: rgb(var(--border));
    transition:
      background-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .status-sequence-dot.is-active {
    background: rgb(var(--primary));
    box-shadow: 0 0 8px rgb(47 217 244 / 0.8);
    transform: scale(1.16);
  }

  :global([data-theme="light"]) .status-sequence-dot.is-active {
    background: #0891b2;
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.42);
  }

  @media (prefers-reduced-motion: reduce) {
    .status-sequence-dot {
      transition: none;
    }

    .status-sequence-dot:first-child {
      background: rgb(var(--primary));
      box-shadow: 0 0 8px rgb(47 217 244 / 0.8);
    }

    :global([data-theme="light"]) .status-sequence-dot:first-child {
      background: #0891b2;
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.42);
    }
  }
</style>
