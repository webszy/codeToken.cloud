---
const statusCards = [
  {
    label: "Server Load",
    value: "CPU 32",
    unit: "%",
    detail: "MEM 61% · Load 0.74",
    iconPath: "M6 8H18M8 4V8M16 4V8M8 16V20M16 16V20M6 16H18M8 8V16M16 8V16M10.5 11H13.5V13H10.5V11Z",
    tone: "cyan"
  },
  {
    label: "Requests",
    value: "18,420",
    detail: "+326 last 5m",
    iconPath: "M7 7H19M19 7L15 3M19 7L15 11M17 17H5M5 17L9 13M5 17L9 21",
    tone: "blue"
  },
  {
    label: "Tokens",
    value: "391.2",
    unit: "M",
    detail: "+8.4M last 5m",
    iconPath: "M12 3L19 7V17L12 21L5 17V7L12 3ZM12 7L8.5 9V15L12 17L15.5 15V9L12 7Z",
    tone: "purple"
  },
  {
    label: "Success Rate",
    value: "99.92",
    unit: "%",
    detail: "Error 0.08%",
    iconPath: "M20 6L9 17L4 12M21 12A9 9 0 1 1 12 3",
    tone: "green"
  },
  {
    label: "Avg QPS",
    value: "1.09",
    detail: "req/s · rolling 5m",
    iconPath: "M4 14A8 8 0 0 1 20 14M12 14L16 9M7 18H17",
    tone: "cyan"
  },
  {
    label: "Avg TPS",
    value: "28.0",
    unit: "K",
    detail: "tok/s · rolling 5m",
    iconPath: "M13 2L4 14H11L10 22L20 9H13V2Z",
    tone: "blue"
  },
  {
    label: "TTFT",
    value: "0.84",
    unit: "s",
    detail: "avg first response",
    iconPath: "M12 7V12L15 15M12 3A9 9 0 1 0 21 12A9 9 0 0 0 12 3Z",
    tone: "amber"
  },
  {
    label: "Upstream",
    value: "Healthy",
    detail: "32 models · OpenAI / Claude / Gemini",
    iconPath: "M12 3A9 9 0 1 0 21 12A9 9 0 0 0 12 3ZM3.6 12H20.4M12 3C14.3 5.4 15.4 8.4 15.4 12C15.4 15.6 14.3 18.6 12 21M12 3C9.7 5.4 8.6 8.4 8.6 12C8.6 15.6 9.7 18.6 12 21",
    tone: "green"
  }
];

const toneClasses = {
  cyan: {
    border: "border-primary/30",
    icon: "text-primary",
    iconBox: "border-primary/20 bg-primary/10",
    value: "text-primary",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(47,217,244,0.15)]"
  },
  blue: {
    border: "border-blue-500/40",
    icon: "text-blue-400",
    iconBox: "border-blue-500/30 bg-blue-500/10",
    value: "text-blue-200",
    detail: "text-blue-400",
    shadow: "hover:shadow-[0_0_25px_rgba(5,102,217,0.15)]"
  },
  purple: {
    border: "border-[rgb(var(--tertiary)_/_0.4)]",
    icon: "text-[rgb(var(--tertiary))]",
    iconBox: "border-[rgb(var(--tertiary)_/_0.3)] bg-[rgb(var(--tertiary)_/_0.1)]",
    value: "text-[rgb(var(--tertiary))]",
    detail: "text-[rgb(var(--tertiary)_/_0.82)]",
    shadow: "hover:shadow-[0_0_25px_rgba(217,176,255,0.15)]"
  },
  green: {
    border: "border-cyan-400/35",
    icon: "text-cyan-300",
    iconBox: "border-cyan-400/30 bg-cyan-400/10",
    value: "text-cyan-300",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(34,211,238,0.15)]"
  },
  amber: {
    border: "border-amber-400/30",
    icon: "text-amber-400",
    iconBox: "border-amber-400/20 bg-amber-400/10",
    value: "text-amber-400",
    detail: "text-muted",
    shadow: "hover:shadow-[0_0_25px_rgba(251,191,36,0.15)]"
  }
} as const;
---

<section id="status" class="status-section relative z-10 overflow-hidden py-24 md:py-28">
  <div class="pointer-events-none absolute left-[12%] top-[14%] h-72 w-72 rounded-full bg-primary/10 blur-[110px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-[14%] right-[14%] h-80 w-80 rounded-full bg-[rgb(var(--tertiary)_/_0.08)] blur-[130px]" aria-hidden="true"></div>

  <div class="site-container relative z-10">
    <header class="mx-auto mb-12 flex max-w-3xl flex-col items-center gap-6 text-center">
      <div id="statusBegin" class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.18em] text-primary">
        <span class="h-2 w-2 rounded-full bg-primary shadow-[0_0_10px_rgba(138,235,255,0.9)]"></span>
        Status
      </div>
      <div>
        <h2 class="headline-gradient font-display text-[34px] font-bold leading-[1.12] tracking-normal md:text-[44px]">
          Live Status
        </h2>
        <p class="mx-auto mt-2 max-w-2xl text-[18px] leading-[1.6] text-muted">Real-time gateway load, usage, and performance snapshot</p>
      </div>
    </header>

    <div class="mb-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        statusCards.map((card) => {
          const classes = toneClasses[card.tone as keyof typeof toneClasses];

          return (
            <article class:list={["status-card group flex flex-col gap-4 rounded-lg border p-6 transition-shadow duration-300", classes.border, classes.shadow]}>
              <div class="flex items-start justify-between gap-4">
                <div class:list={["flex items-center gap-2", classes.icon]}>
                  <div class:list={["flex h-8 w-8 items-center justify-center rounded-lg border", classes.iconBox]}>
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                      <path d={card.iconPath} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </div>
                  <span class="font-mono text-[12px] font-semibold uppercase leading-none tracking-[0.12em] text-foreground">{card.label}</span>
                </div>
                <svg class="h-4 w-4 shrink-0 text-muted/45 transition group-hover:text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 17V11M12 7.25V7M21 12A9 9 0 1 1 3 12A9 9 0 0 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </div>

              <div>
                <div class:list={["font-display text-[42px] font-bold leading-none tracking-normal transition-colors", classes.value]}>
                  {card.value}
                  {card.unit && <span class="text-[28px]">{card.unit}</span>}
                </div>
                <div class:list={["mt-3 font-mono text-[14px] leading-[1.5]", classes.detail]}>{card.detail}</div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="status-card flex flex-col items-center justify-between gap-4 rounded-lg border border-border/35 px-6 py-4 md:flex-row">
      <div class="flex items-center gap-3 font-mono text-[14px] leading-[1.5] text-muted">
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 17V11M12 7.25V7M21 12A9 9 0 1 1 3 12A9 9 0 0 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>Last updated 2 minutes ago · Data window: rolling 5 minutes</span>
      </div>
      <div class="flex items-center gap-2" data-status-dot-sequence aria-label="Status sample points">
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
        <span class="status-sequence-dot"></span>
      </div>
    </div>
  </div>
</section>

<script>
  const statusDotSequences = document.querySelectorAll<HTMLElement>("[data-status-dot-sequence]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const sequence = [0, 1, 2, 3, 4, 3, 2, 1];

  statusDotSequences.forEach((container) => {
    const dots = Array.from(container.querySelectorAll<HTMLElement>(".status-sequence-dot"));
    if (dots.length === 0) return;

    let step = 0;

    const setActiveDot = (index: number) => {
      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("is-active", dotIndex === index);
      });
    };

    setActiveDot(0);

    if (reducedMotion.matches) return;

    window.setInterval(() => {
      step = (step + 1) % sequence.length;
      setActiveDot(sequence[step]);
    }, 420);
  });
</script>

<style>
  .status-section {
    background:
      linear-gradient(rgb(var(--background) / 0.9), rgb(var(--background) / 0.96)),
      radial-gradient(circle at 20% 20%, rgb(var(--primary) / 0.1), transparent 24rem),
      radial-gradient(circle at 82% 74%, rgb(var(--tertiary) / 0.07), transparent 26rem);
  }

  .status-card {
    background: linear-gradient(180deg, rgb(var(--surface-container) / 0.78), rgb(var(--surface-lowest) / 0.94));
    box-shadow:
      0 24px 80px rgb(0 0 0 / 0.22),
      inset 0 1px 0 rgb(255 255 255 / 0.04);
    backdrop-filter: blur(20px);
  }

  .status-sequence-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: rgb(var(--border));
    transition:
      background-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .status-sequence-dot.is-active {
    background: rgb(var(--primary));
    box-shadow: 0 0 8px rgb(47 217 244 / 0.8);
    transform: scale(1.16);
  }

  @media (prefers-reduced-motion: reduce) {
    .status-sequence-dot {
      transition: none;
    }

    .status-sequence-dot:first-child {
      background: rgb(var(--primary));
      box-shadow: 0 0 8px rgb(47 217 244 / 0.8);
    }
  }
</style>
