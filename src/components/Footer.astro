---
import type { SiteCopy } from "../i18n";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<footer class="relative z-10 border-t border-border/20 bg-[rgb(var(--surface-lowest))]">
  <div class="site-container flex min-h-20 flex-col items-center justify-center gap-2 py-4 text-center text-[15px] text-muted sm:min-h-[58px] sm:flex-row sm:gap-6 sm:py-[7px]">
    <p>{copy.footer.copyright}</p>
    <a
      class="inline-grid h-11 w-11 place-items-center rounded-md border border-border/70 text-primary transition hover:border-primary/70 hover:text-foreground focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      href={`mailto:${copy.footer.contactEmail}`}
      aria-label={`Contact ${copy.footer.contactEmail}`}
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.75 6.75H19.25V17.25H4.75V6.75Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        <path d="M5.25 7.25L12 12.75L18.75 7.25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</footer>
