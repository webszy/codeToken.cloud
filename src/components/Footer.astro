---
import type { SiteCopy } from "../i18n";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const columns = [
  { title: copy.footer.product, links: copy.footer.productLinks },
  { title: copy.footer.developers, links: copy.footer.developerLinks },
  { title: copy.footer.company, links: copy.footer.companyLinks }
];
---

<footer class="py-12">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 sm:px-6 md:grid-cols-[1.2fr_2fr] lg:px-8">
    <div>
      <p class="font-display text-lg font-extrabold tracking-normal text-foreground">{copy.brand.name}</p>
      <p class="mt-3 max-w-sm leading-7 text-muted">{copy.brand.tagline}</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      {
        columns.map((column) => (
          <div>
            <h2 class="text-sm font-bold uppercase tracking-[0.16em] text-foreground">{column.title}</h2>
            <ul class="mt-4 space-y-3">
              {column.links.map((link) => (
                <li>
                  <a class="text-sm font-medium text-muted transition hover:text-foreground" href="#">
                    {link}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</footer>
