---
import type { SiteCopy } from "../i18n";

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section id="features" class="border-y border-border/70 bg-card/35 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-primary">{copy.sections.featuresEyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold tracking-normal text-foreground sm:text-4xl">
        {copy.sections.featuresTitle}
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        copy.features.map((feature, index) => (
          <article class="rounded-lg border border-border bg-background/70 p-5 transition hover:border-primary/50">
            <div class="mb-5 grid h-11 w-11 place-items-center rounded-md bg-primary/10 text-primary">
              <span class="font-mono text-sm font-bold">{String(index + 1).padStart(2, "0")}</span>
            </div>
            <h3 class="font-display text-lg font-bold tracking-normal text-foreground">{feature.title}</h3>
            <p class="mt-3 leading-7 text-muted">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
